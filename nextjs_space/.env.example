# Variáveis de Ambiente - EXEMPLO
# Copie este arquivo para .env.local (desenvolvimento) ou .env.production (produção)
# Não versionie dados sensíveis - use GitHub Secrets

# ========== BANCO DE DADOS ==========
DATABASE_URL="postgresql://user:password@localhost:5432/tobias_db"

# ========== NEXTAUTH ==========
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="seu_valor_secreto_muito_seguro_aqui_min_32_chars"

# ========== AWS S3 ==========
NEXT_PUBLIC_AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="sua_chave_de_acesso"
AWS_SECRET_ACCESS_KEY="sua_chave_secreta"
AWS_S3_BUCKET="seu_bucket_nome"

# ========== AZURE STORAGE ==========
AZURE_STORAGE_ACCOUNT_NAME="seu_account"
AZURE_STORAGE_ACCOUNT_KEY="sua_chave"
AZURE_STORAGE_CONTAINER="seu_container"

# ========== API PÚBLICA ==========
NEXT_PUBLIC_API_URL="https://seu-dominio.com.br/api"

# ========== EMAIL ==========
SMTP_HOST="smtp.seumail.com"
SMTP_PORT=587
SMTP_USER="seu_email@seumail.com"
SMTP_PASSWORD="sua_senha_email"
SMTP_FROM="noreply@seu-dominio.com.br"

# ========== AMBIENTE ==========
NODE_ENV="development"
PORT=3000

# ========== DEBUG ==========
DEBUG="false"
LOG_LEVEL="info"
